# PubTator-Link Nginx Proxy Manager deployment
# Copy to .env.docker on the VPS and customize before starting the stack.

# Nginx Proxy Manager shared Docker network.
NPM_SHARED_NETWORK_NAME=npm_default

# Public hostname served by Nginx Proxy Manager.
PUBTATOR_LINK_PUBLIC_DOMAIN=pubtator.example.com
PUBTATOR_LINK_PUBLIC_URL=https://pubtator.example.com
PUBTATOR_LINK_CORS_ORIGINS=["https://pubtator.example.com"]
# Keep the public Origin allowlist identical to CORS. Hosts are exact; wildcards fail startup.
PUBTATOR_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1","pubtator.example.com"]
PUBTATOR_LINK_ALLOWED_ORIGINS=["https://pubtator.example.com"]

# Replace before deployment: openssl rand -hex 32. Configure the same value as
# GF_PUBTATOR_TOKEN on the GeneFoundry router without committing either secret.
PUBTATOR_LINK_MCP_SERVICE_TOKEN=replace-with-random-service-token

# PostgreSQL credentials used by docker/docker-compose.yml.
PUBTATOR_LINK_POSTGRES_DB=pubtator_link
PUBTATOR_LINK_POSTGRES_USER=pubtator_link
# REQUIRED secret — the prod/npm overlays fail closed (no fallback) when this is
# unset. Generate a fresh value (openssl rand -hex 32) and inject it from your
# secret store / shell environment at deploy time. Do NOT commit a real value or
# ship a predictable placeholder: `docker compose config` renders whatever this
# resolves to verbatim, so a committed `change-me` would become the deployed
# database credential.
# PUBTATOR_LINK_POSTGRES_PASSWORD=

# Optional host port for local development compose runs.
# Production and NPM overlays remove published ports.
PUBTATOR_LINK_POSTGRES_PORT=5434
