{
  "mcpServers": {
    "pubtator-link-stdio": {
      "command": "python",
      "args": ["/absolute/path/to/pubtator-link/mcp_server.py"],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "LOG_LEVEL": "WARNING"
      }
    },
    "pubtator-link-http": {
      "transport": {
        "type": "http",
        "url": "http://localhost:8000/mcp"
      }
    }
  }
}