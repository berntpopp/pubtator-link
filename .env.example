# Every setting is read under the PUBTATOR_LINK_ prefix (pubtator_link/config.py sets
# env_prefix="PUBTATOR_LINK_", extra="ignore"). An unprefixed name is SILENTLY IGNORED —
# no error, no warning, no effect. Do not drop the prefix.

# Server Configuration
PUBTATOR_LINK_HOST=127.0.0.1
PUBTATOR_LINK_PORT=8000
PUBTATOR_LINK_TRANSPORT=unified

# MCP security. The default hosted surface is read-only. Generate a service token
# before enabling lean/full or using Docker Compose: openssl rand -hex 32
PUBTATOR_LINK_MCP_PROFILE=readonly
PUBTATOR_LINK_MCP_SERVICE_TOKEN=
PUBTATOR_LINK_ALLOW_UNAUTHENTICATED_WRITES=false
PUBTATOR_LINK_ALLOWED_HOSTS=localhost,127.0.0.1,::1
PUBTATOR_LINK_ALLOWED_ORIGINS=
PUBTATOR_LINK_REVIEW_EXPORT_BASE_DIR=

# Edge auth. AUTH_MODE=none (default) keeps today's behavior (open, or token-gated
# when MCP_SERVICE_TOKEN is set). AUTH_MODE=oauth serves one /mcp to standalone
# Keycloak-OAuth users AND the router (its static token); requires a full/lean profile,
# the vars below, and a persistent FASTMCP_HOME volume. See docs/SECURITY.md.
PUBTATOR_LINK_AUTH_MODE=none
# PUBTATOR_LINK_OAUTH_AUTHORIZE_URL=
# PUBTATOR_LINK_OAUTH_TOKEN_URL=
# PUBTATOR_LINK_OAUTH_CLIENT_ID=
# PUBTATOR_LINK_OAUTH_CLIENT_SECRET=
# PUBTATOR_LINK_OAUTH_JWT_SIGNING_KEY=      # openssl rand -hex 32; stable across restarts
# PUBTATOR_LINK_OAUTH_ALLOWED_CLIENT_REDIRECT_URIS=https://claude.ai/*,http://127.0.0.1:*
# PUBTATOR_LINK_JWT_ISSUER=
# PUBTATOR_LINK_JWT_JWKS_URL=
# PUBTATOR_LINK_JWT_AUDIENCE=               # == PUBLIC_BASE_URL + /mcp
# PUBTATOR_LINK_PUBLIC_BASE_URL=            # bare https origin, no path
# PUBTATOR_LINK_REQUIRE_WRITE_SCOPE=false   # true reserves writes for the pubtator:write scope

# API Configuration
PUBTATOR_LINK_API_BASE_URL=https://www.ncbi.nlm.nih.gov/research/pubtator3-api
PUBTATOR_LINK_API_TIMEOUT=30
# PubTator3 permits at most 3 requests/second — do not raise this above 3.
PUBTATOR_LINK_RATE_LIMIT_PER_SECOND=2.5

# Text Processing API
PUBTATOR_LINK_TEXT_API_BASE_URL=https://www.ncbi.nlm.nih.gov/CBBresearch/Lu/Demo/RESTful
PUBTATOR_LINK_TEXT_API_TIMEOUT=60

# Cache Configuration
PUBTATOR_LINK_CACHE_SIZE=1000
PUBTATOR_LINK_CACHE_TTL=3600

# Logging Configuration
PUBTATOR_LINK_LOG_LEVEL=INFO
PUBTATOR_LINK_LOG_FORMAT=console

# CORS Configuration
PUBTATOR_LINK_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Feature Flags
PUBTATOR_LINK_ENABLE_DOCS=true
# Opt-in cache management REST endpoints. Default-off on purpose; these names were
# previously unprefixed here (and therefore inert), so leave this at the secure
# default rather than switching the surface on for every `cp .env.example .env`.
PUBTATOR_LINK_ENABLE_CACHE_ENDPOINTS=false

# Review re-RAG PostgreSQL configuration for Docker Compose
PUBTATOR_LINK_POSTGRES_DB=pubtator_link
PUBTATOR_LINK_POSTGRES_USER=pubtator_link
PUBTATOR_LINK_POSTGRES_PASSWORD=pubtator_link
PUBTATOR_LINK_POSTGRES_PORT=5434
PUBTATOR_LINK_DATABASE_URL=postgresql://pubtator_link:pubtator_link@localhost:5434/pubtator_link
