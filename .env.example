# Server Configuration
HOST=127.0.0.1
PORT=8000
TRANSPORT=unified

# API Configuration
API_BASE_URL=https://www.ncbi.nlm.nih.gov/research/pubtator3-api
API_TIMEOUT=30
RATE_LIMIT_PER_SECOND=2.5

# Text Processing API
TEXT_API_BASE_URL=https://www.ncbi.nlm.nih.gov/CBBresearch/Lu/Demo/RESTful
TEXT_API_TIMEOUT=60

# Cache Configuration
CACHE_SIZE=1000
CACHE_TTL=3600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=console

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Feature Flags
ENABLE_DOCS=true
ENABLE_CACHE_ENDPOINTS=true